  endings:
  - id: help_too_late
    result: 1
    title: "\u0412\u044B \u043D\u0435 \u0443\u0441\u043F\u0435\u043B\u0438... "
    description: "\u0412\u044B \u0432\u044B\u0431\u0440\u0430\u043B\u0438 \u043F\u0443\u0442\u044C
      \u043A \u043A\u043E\u043C\u043D\u0430\u0442\u0435 \u0443\u043F\u0440\u0430\u0432\u043B\u0435\u043D\u0438\u044F
      \u0438 \u043F\u043E\u0442\u0435\u0440\u044F\u043B\u0438 \u043A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
      \u0432\u0440\u0435\u043C\u044F.\r\n\r\n\u041F\u043E\u043A\u0430 \u044D\u043A\u0438\u043F\u0430\u0436
      \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u043E\u0446\u0435\u043D\u0438\u0442\u044C
      \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u044E, \u0442\u043E\u043F\u043B\u0438\u0432\u043E
      \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B\u043E \u043F\u043E\u0441\u0442\u0443\u043F\u0430\u0442\u044C
      \u0432 \u043C\u0430\u0448\u0438\u043D\u043D\u043E\u0435 \u043E\u0442\u0434\u0435\u043B\u0435\u043D\u0438\u0435.
      \u041E\u0433\u043E\u043D\u044C \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0438\u043B\u0441\u044F
      \u0434\u0430\u043B\u044C\u0448\u0435, \u0438 \u043F\u0440\u0438 \u043F\u043E\u043F\u044B\u0442\u043A\u0435
      \u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F \u0441\u0442\u0430\u043B\u043E
      \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u043F\u043E\u0437\u0434\u043D\u043E.\r\n\r\n\u041A\u043E\u0440\u0430\u0431\u043B\u044C
      \u0431\u044B\u043B \u043F\u043E\u0442\u0435\u0440\u044F\u043D."
    endingClip: {fileID: 0}
    fadeOutBeforeShow: 1
    fadeOutDuration: 0.6
    delayBeforePanel: 0.4
    pauseGameAfterShow: 1
  - id: iof_wrong_solution
    result: 1
    title: "\u041B\u043E\u0436\u043D\u043E\u0435 \u0441\u043F\u0430\u0441\u0435\u043D\u0438\u0435 "
    description: "\u0421\u0438\u0441\u0442\u0435\u043C\u0430 \u043F\u043E\u0436\u0430\u0440\u043E\u0442\u0443\u0448\u0435\u043D\u0438\u044F
      \u0432\u0440\u0435\u043C\u0435\u043D\u043D\u043E \u043F\u043E\u0434\u0430\u0432\u0438\u043B\u0430
      \u043E\u0442\u043A\u0440\u044B\u0442\u043E\u0435 \u043F\u043B\u0430\u043C\u044F,
      \u043E\u0434\u043D\u0430\u043A\u043E \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A
      \u043F\u043E\u0436\u0430\u0440\u0430 \u043D\u0435 \u0431\u044B\u043B \u0443\u0441\u0442\u0440\u0430\u043D\u0451\u043D.
      \u041F\u043E\u0434\u0430\u0447\u0430 \u0442\u043E\u043F\u043B\u0438\u0432\u0430
      \u0432 \u043C\u0430\u0448\u0438\u043D\u043D\u043E\u0435 \u043E\u0442\u0434\u0435\u043B\u0435\u043D\u0438\u0435
      \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B\u0430\u0441\u044C, \u0430
      \u0442\u0435\u043C\u043F\u0435\u0440\u0430\u0442\u0443\u0440\u0430 \u0432 \u043E\u0442\u0441\u0435\u043A\u0435
      \u043E\u0441\u0442\u0430\u0432\u0430\u043B\u0430\u0441\u044C \u043A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u0438
      \u0432\u044B\u0441\u043E\u043A\u043E\u0439.\n\n\u041F\u043E\u0441\u043B\u0435
      \u0441\u043D\u044F\u0442\u0438\u044F \u0433\u0435\u0440\u043C\u0435\u0442\u0438\u0437\u0430\u0446\u0438\u0438
      \u0438 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u044F \u0434\u0432\u0435\u0440\u0438
      \u0432 \u043F\u043E\u043C\u0435\u0449\u0435\u043D\u0438\u0435 \u043F\u043E\u0441\u0442\u0443\u043F\u0438\u043B
      \u043A\u0438\u0441\u043B\u043E\u0440\u043E\u0434. \u042D\u0442\u043E \u043F\u0440\u0438\u0432\u0435\u043B\u043E
      \u043A \u043F\u043E\u0432\u0442\u043E\u0440\u043D\u043E\u043C\u0443 \u0432\u043E\u0441\u043F\u043B\u0430\u043C\u0435\u043D\u0435\u043D\u0438\u044E
      \u0433\u043E\u0440\u044E\u0447\u0435\u0439 \u0441\u043C\u0435\u0441\u0438 \u0438
      \u0432\u0437\u0440\u044B\u0432\u0443.\n\n\u0412 \u0443\u0441\u043B\u043E\u0432\u0438\u044F\u0445
      \u043F\u043E\u0436\u0430\u0440\u0430 \u043D\u0430 \u043A\u043E\u0440\u0430\u0431\u043B\u0435
      \u043D\u0435\u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E \u0442\u043E\u043B\u044C\u043A\u043E
      \u0441\u0431\u0438\u0442\u044C \u043F\u043B\u0430\u043C\u044F. \u041D\u0435\u043E\u0431\u0445\u043E\u0434\u0438\u043C\u043E
      \u0443\u0441\u0442\u0440\u0430\u043D\u0438\u0442\u044C \u043F\u0440\u0438\u0447\u0438\u043D\u0443
      \u0433\u043E\u0440\u0435\u043D\u0438\u044F: \u043F\u0435\u0440\u0435\u043A\u0440\u044B\u0442\u044C
      \u043F\u043E\u0434\u0430\u0447\u0443 \u0442\u043E\u043F\u043B\u0438\u0432\u0430
      \u0438 \u0438\u0437\u043E\u043B\u0438\u0440\u043E\u0432\u0430\u0442\u044C \u0438\u0441\u0442\u043E\u0447\u043D\u0438\u043A
      \u043E\u043F\u0430\u0441\u043D\u043E\u0441\u0442\u0438.\n\n\u0412\u044B \u0432\u044B\u0431\u0440\u0430\u043B\u0438
      \u0442\u0443\u0448\u0435\u043D\u0438\u0435, \u043D\u043E \u043D\u0435 \u043F\u0435\u0440\u0435\u043A\u0440\u044B\u043B\u0438
      \u0442\u043E\u043F\u043B\u0438\u0432\u043E."
    endingClip: {fileID: 0}
