      \u0438 \u043F\u043E\u0442\u0435\u0440\u044F\u043B\u0438 \u043A\u0440\u0438\u0442\u0438\u0447\u0435\u0441\u043A\u043E\u0435
      \u0432\u0440\u0435\u043C\u044F.\r\n\r\n\u041F\u043E\u043A\u0430 \u044D\u043A\u0438\u043F\u0430\u0436
      \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u043E\u0446\u0435\u043D\u0438\u0442\u044C
      \u0441\u0438\u0442\u0443\u0430\u0446\u0438\u044E, \u0442\u043E\u043F\u043B\u0438\u0432\u043E
      \u043F\u0440\u043E\u0434\u043E\u043B\u0436\u0430\u043B\u043E \u043F\u043E\u0441\u0442\u0443\u043F\u0430\u0442\u044C
      \u0432 \u043C\u0430\u0448\u0438\u043D\u043D\u043E\u0435 \u043E\u0442\u0434\u0435\u043B\u0435\u043D\u0438\u0435.
      \u041E\u0433\u043E\u043D\u044C \u0440\u0430\u0441\u043F\u0440\u043E\u0441\u0442\u0440\u0430\u043D\u0438\u043B\u0441\u044F
      \u0434\u0430\u043B\u044C\u0448\u0435, \u0438 \u043F\u0440\u0438 \u043F\u043E\u043F\u044B\u0442\u043A\u0435
      \u0432\u0435\u0440\u043D\u0443\u0442\u044C\u0441\u044F \u0441\u0442\u0430\u043B\u043E
      \u0441\u043B\u0438\u0448\u043A\u043E\u043C \u043F\u043E\u0437\u0434\u043D\u043E.\r\n\r\n\u041A\u043E\u0440\u0430\u0431\u043B\u044C
      \u0431\u044B\u043B \u043F\u043E\u0442\u0435\u0440\u044F\u043D."
