  notReadyThought: "\u0421\u043D\u0430\u0447\u0430\u043B\u0430 \u043D\u0443\u0436\u043D\u043E
    \u043F\u043E\u0434\u0433\u043E\u0442\u043E\u0432\u0438\u0442\u044C \u043F\u043E\u043C\u0435\u0449\u0435\u043D\u0438\u0435:
    \u0437\u0430\u043A\u0440\u044B\u0442\u044C \u0434\u0432\u0435\u0440\u044C, \u043E\u0442\u043A\u043B\u044E\u0447\u0438\u0442\u044C
    \u0432\u0435\u043D\u0442\u0438\u043B\u044F\u0446\u0438\u044E \u0438 \u0432\u043A\u043B\u044E\u0447\u0438\u0442\u044C
    \u0433\u0435\u0440\u043C\u0435\u0442\u0438\u0437\u0430\u0446\u0438\u044E."
  systemStartedThought: "\u0421\u0438\u0441\u0442\u0435\u043C\u0430 \u043F\u043E\u0436\u0430\u0440\u043E\u0442\u0443\u0448\u0435\u043D\u0438\u044F
    \u0437\u0430\u043F\u0443\u0449\u0435\u043D\u0430."
  fireExtinguishedThought: "\u041F\u043E\u0436\u0430\u0440 \u043F\u043E\u0442\u0443\u0448\u0435\u043D!"
  systemStartedUiMessage: "\u0421\u0438\u0441\u0442\u0435\u043C\u0430 \u043F\u043E\u0436\u0430\u0440\u043E\u0442\u0443\u0448\u0435\u043D\u0438\u044F
    \u0430\u043A\u0442\u0438\u0432\u0438\u0440\u043E\u0432\u0430\u043D\u0430"
