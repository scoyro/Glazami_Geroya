  systemReadyThought: "\u0421\u0438\u0441\u0442\u0435\u043C\u0430 \u0433\u043E\u0442\u043E\u0432\u0430."
  suppressionStillWorkingThought: "\u0421\u0438\u0441\u0442\u0435\u043C\u0443 \u043D\u0435\u043B\u044C\u0437\u044F
