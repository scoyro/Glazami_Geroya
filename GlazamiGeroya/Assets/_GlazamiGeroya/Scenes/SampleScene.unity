    \u0433\u0435\u0440\u043C\u0435\u0442\u0438\u0437\u0430\u0446\u0438\u0438."
  roomAlreadySealedHover: 
  suppressionWorkingHover: "\u041D\u0430\u0436\u0430\u0442\u044C \u043A\u043D\u043E\u043F\u043A\u0443
    \u0433\u0435\u0440\u043C\u0435\u0442\u0438\u0437\u0430\u0446\u0438\u0438."
  unsealRoomHover: "\u041D\u0430\u0436\u0430\u0442\u044C \u043A\u043D\u043E\u043F\u043A\u0443
    \u0433\u0435\u0440\u043C\u0435\u0442\u0438\u0437\u0430\u0446\u0438\u0438."
  roomUnsealedHover: "\u041D\u0430\u0436\u0430\u0442\u044C \u043A\u043D\u043E\u043F\u043A\u0443
    \u0433\u0435\u0440\u043C\u0435\u0442\u0438\u0437\u0430\u0446\u0438\u0438."
  doorOpenThought: "\u0421\u043D\u0430\u0447\u0430\u043B\u0430 \u043D\u0443\u0436\u043D\u043E
    \u0437\u0430\u043A\u0440\u044B\u0442\u044C \u0434\u0432\u0435\u0440\u044C."
  ventilationAlreadyDisabledThought: "\u0412\u0435\u043D\u0442\u0438\u043B\u044F\u0446\u0438\u044F
    \u0443\u0436\u0435 \u043E\u0442\u043A\u043B\u044E\u0447\u0435\u043D\u0430."
  ventilationRequiredThought: "\u0421\u043D\u0430\u0447\u0430\u043B\u0430 \u043D\u0443\u0436\u043D\u043E
    \u043E\u0442\u043A\u043B\u044E\u0447\u0438\u0442\u044C \u0432\u0435\u043D\u0442\u0438\u043B\u044F\u0446\u0438\u044E."
  ventilationDisabledThought: "\u0412\u0435\u043D\u0442\u0438\u043B\u044F\u0446\u0438\u044F
    \u043E\u0442\u043A\u043B\u044E\u0447\u0435\u043D\u0430."
  sealingMessage: "\u0413\u0435\u0440\u043C\u0435\u0442\u0438\u0437\u0430\u0446\u0438\u044F
    \u043F\u043E\u043C\u0435\u0449\u0435\u043D\u0438\u044F"
  systemReadyThought: "\u0421\u0438\u0441\u0442\u0435\u043C\u0430 \u0433\u043E\u0442\u043E\u0432\u0430."
  suppressionStillWorkingThought: "\u0421\u0438\u0441\u0442\u0435\u043C\u0443 \u043D\u0435\u043B\u044C\u0437\u044F
    \u043E\u0442\u043A\u043B\u044E\u0447\u0430\u0442\u044C, \u043F\u043E\u043A\u0430
    \u043F\u043E\u0436\u0430\u0440\u043E\u0442\u0443\u0448\u0435\u043D\u0438\u0435
    \u043D\u0435 \u0437\u0430\u0432\u0435\u0440\u0448\u0435\u043D\u043E."
  unsealedThought: "\u0413\u0435\u0440\u043C\u0435\u0442\u0438\u0437\u0430\u0446\u0438\u044F
    \u0441\u043D\u044F\u0442\u0430. \u0414\u0432\u0435\u0440\u044C \u043C\u043E\u0436\u043D\u043E
    \u043E\u0442\u043A\u0440\u044B\u0442\u044C."
  unsealedUiMessage: "\u0413\u0435\u0440\u043C\u0435\u0442\u0438\u0437\u0430\u0446\u0438\u044F
    \u0441\u043D\u044F\u0442\u0430"
